# Copy this file to .env (or just export these in your shell) and fill in your key.
#
# Groq is free -- no credit card required. Get a key at console.groq.com
# (left sidebar -> API Keys -> Create API Key).
GROQ_API_KEY=gsk_your-key-here

# Optional: override the default model.
# llama-3.3-70b-versatile (default) -- best quality, free tier
# llama-3.1-8b-instant -- faster, use if you hit rate limits during testing
AGENT_MODEL=llama-3.3-70b-versatile
